<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="DEBUG">
    <Properties>
        <Property name="logPattern">%d{HH:mm:ss} %-6p-> %c{1}.%M(%F:%L) - %m%n</Property>
        <Property name="logPath">logs/</Property>
        <Property name="rollingFileName">elite-intel</Property>
    </Properties>

    <Appenders>
        <Console name="console" target="SYSTEM_OUT">
            <PatternLayout pattern="${logPattern}"/>
        </Console>
        <RollingFile name="rollingFile" fileName="${logPath}/${rollingFileName}.log" filePattern="${logPath}/${rollingFileName}_%d{yyyy-MM-dd}.log" immediateFlush="true">
            <PatternLayout pattern="${logPattern}"/>
            <Policies>
                <OnStartupTriggeringPolicy/>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="1MB"/>
            </Policies>
            <DefaultRolloverStrategy max="7"/>
        </RollingFile>
        <RollingFile name="unknownEnumFile"
                     fileName="${logPath}/unknown-enum.log"
                     filePattern="${logPath}/unknown-enum_%d{yyyy-MM-dd}.log"
                     immediateFlush="true">
            <PatternLayout pattern="${logPattern}"/>
            <Policies>
                <OnStartupTriggeringPolicy/>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="1MB"/>
            </Policies>
            <DefaultRolloverStrategy max="5"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Suppress third-party logs -->
        <Logger name="io.grpc" level="off"/>
        <Logger name="io.grpc.netty" level="off"/>
        <Logger name="io.grpc.netty.shaded" level="off"/>
        <Logger name="io.netty" level="off"/>

        <Logger name="org.apache" level="off"/>
        <Logger name="org.sqlite" level="off"/>
        <Logger name="org.sqlite.core" level="off"/>
        <Logger name="org.sqlite.jdbc" level="off"/>
        <Logger name="org.jdbi.v3.core" level="off"/>
        <Logger name="org.jdbi.v3" level="off"/>
        <Logger name="org" level="off"/>
        <Logger name="com" level="off"/>


        <!-- Specific logger levels -->
        <Logger name="elite.vault" level="error"/>
        <Logger name="elite.vault.util.UnknownEnumLogger"
                level="error"
                additivity="false">
            <AppenderRef ref="unknownEnumFile"/>
        </Logger>

        <!-- Root logger -->
        <Root level="debug">
            <AppenderRef ref="rollingFile"/>
            <AppenderRef ref="console"/>
        </Root>
    </Loggers>
</Configuration>